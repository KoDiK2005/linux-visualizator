{
    "head0": {
        "type": "header",
        "description": "Linux Visualizator"
    },
    "refresh-interval": {
        "type": "spinbutton",
        "default": 1000,
        "min": 200,
        "max": 5000,
        "step": 100,
        "unit": "ms",
        "description": "Интервал опроса",
        "tooltip": "Как часто опрашивать системные метрики."
    },
    "background-opacity": {
        "type": "spinbutton",
        "default": 205,
        "min": 40,
        "max": 255,
        "step": 5,
        "description": "Непрозрачность фона",
        "tooltip": "0 — почти прозрачный, 255 — полностью непрозрачный."
    },
    "click-command": {
        "type": "entry",
        "default": "gnome-system-monitor",
        "description": "Команда по клику",
        "tooltip": "Запускается по левому клику на десклете. Пусто — отключить."
    },
    "ui-scale": {
        "type": "spinbutton",
        "default": 100,
        "min": 75,
        "max": 150,
        "step": 5,
        "unit": "%",
        "description": "Масштаб интерфейса",
        "tooltip": "Размер колец/полос/шрифтов относительно стандартного."
    },
    "panel-order": {
        "type": "entry",
        "default": "cpu,mem,net,disk",
        "description": "Порядок секций",
        "tooltip": "Через запятую: cpu,mem,net,disk. Пропущенные секции добавляются в конец."
    },
    "warn-threshold": {
        "type": "spinbutton",
        "default": 70,
        "min": 1,
        "max": 99,
        "step": 1,
        "unit": "%",
        "description": "Жёлтый порог",
        "tooltip": "Выше этого процента индикатор окрашивается в жёлтый."
    },
    "bad-threshold": {
        "type": "spinbutton",
        "default": 90,
        "min": 2,
        "max": 100,
        "step": 1,
        "unit": "%",
        "description": "Красный порог",
        "tooltip": "Выше этого процента индикатор окрашивается в красный."
    },

    "head-cpu": {
        "type": "header",
        "description": "Процессор"
    },
    "show-cpu": {
        "type": "switch",
        "default": true,
        "description": "Показывать CPU"
    },
    "cpu-view": {
        "type": "combobox",
        "default": "rings",
        "options": {
            "Кольца по ядрам": "rings",
            "Полосы по ядрам": "bars",
            "График общей загрузки": "graph"
        },
        "description": "Вид отображения CPU",
        "tooltip": "Как показывать загрузку процессора.",
        "dependency": "show-cpu"
    },
    "show-cpu-freq": {
        "type": "switch",
        "default": true,
        "description": "Показывать частоту CPU",
        "dependency": "show-cpu"
    },
    "show-cpu-temp": {
        "type": "switch",
        "default": true,
        "description": "Показывать температуру CPU (если доступна)",
        "dependency": "show-cpu"
    },

    "head-mem": {
        "type": "header",
        "description": "Память"
    },
    "show-mem": {
        "type": "switch",
        "default": true,
        "description": "Показывать RAM/Swap"
    },

    "head-net": {
        "type": "header",
        "description": "Сеть"
    },
    "show-net": {
        "type": "switch",
        "default": true,
        "description": "Показывать сеть"
    },
    "network-interface": {
        "type": "entry",
        "default": "",
        "description": "Сетевые интерфейсы",
        "tooltip": "Например, wlan0 или enp3s0,wlan0 через запятую. Пусто — суммировать все интерфейсы, кроме lo.",
        "dependency": "show-net"
    },
    "net-unit": {
        "type": "combobox",
        "default": "bytes",
        "options": {
            "Байты (KB/s)": "bytes",
            "Биты (Kb/s)": "bits"
        },
        "description": "Единицы измерения сети",
        "dependency": "show-net"
    },

    "head-disk": {
        "type": "header",
        "description": "Диски"
    },
    "show-disk": {
        "type": "switch",
        "default": true,
        "description": "Показывать диски"
    },
    "disk-filter": {
        "type": "entry",
        "default": "",
        "description": "Разделы дисков",
        "tooltip": "Подстроки точек монтирования через запятую, например: /, /home. Пусто — показывать все.",
        "dependency": "show-disk"
    }
}
